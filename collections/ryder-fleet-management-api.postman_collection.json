  "info": {
    "_postman_id": "f4c380b7-feff-48f0-a66e-d59deea9ed25",
    "name": "Ryder Fleet Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Ryder Fleet Management API enables seamless integration of fleet and location data into business systems. It provides access to Ryder fleet details including vehicle information and specifications, location data with address and service hours, historical maintenance records, and invoice details with line items and payment status.\n\nContact Support:\n Name: Ryder Developer Portal",
